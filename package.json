{
  "name": "zippy",
  "private": true,
  "packageManager": "bun@1.3.12",
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@types/bun": "latest",
      "oxlint": "^1.71.0",
      "oxlint-tsgolint": "^0.23.0",
      "prettier": "3.4.2",
      "prettier-plugin-jsdoc": "^1.8.0",
      "turbo": "^2.9.7",
      "typescript": "^6.0.3",
      "zshy": "^0.7.2"
    }
  },
  "scripts": {
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "build": "turbo run build",
    "format": "prettier . --write",
    "fix": "turbo run lint:fix && bun run format",
    "check": "bun run typecheck && bun run fix && bun run test && bun run build && bun run pack:dry",
    "pack:dry": "turbo run pack:dry",
    "publish:zippy": "bun run --cwd packages/zippy publish:public"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-jsdoc": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
