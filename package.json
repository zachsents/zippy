{
  "name": "zippy",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.12",
  "prettier": "@zachsents/prettier-config",
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@types/bun": "latest",
      "oxlint": "^1.74.0",
      "oxlint-tsgolint": "^0.24.0",
      "prettier": "^3.9.5",
      "turbo": "^2.9.7",
      "typescript": "^6.0.3",
      "zshy": "^0.7.2"
    }
  },
  "scripts": {
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "build": "turbo run build",
    "format": "prettier . --write",
    "fix": "turbo run lint:fix && bun run format",
    "check": "bun run typecheck && bun run fix && bun run test && bun run build && bun run pack:dry",
    "pack:dry": "turbo run pack:dry"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@zachsents/oxlint-config": "^0.2.7",
    "@zachsents/prettier-config": "^0.1.1",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}
